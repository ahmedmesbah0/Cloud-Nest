# ─── Application ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── API URL (used by Next.js frontend) ─────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql://cloudnest:cloudnest@localhost:5432/cloudnest

# ─── Redis (BullMQ queue backend) ──────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Proxmox (used by ProxmoxService, never exposed to frontend) ──
PROXMOX_HOST=
PROXMOX_API_TOKEN_ID=
PROXMOX_API_TOKEN_SECRET=
PROXMOX_NODE=
PROXMOX_STORAGE=

# ─── SMTP (email verification, password reset) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cloudnest.io

# ─── 2FA ────────────────────────────────────────────────
TOTP_ISSUER=CloudNest

# ─── Rate Limiting ──────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
