# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cloudnest?schema=public

# Redis (required by BullMQ)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API URL (used for verification links etc)
NEXT_PUBLIC_API_URL=http://localhost:3000

# TOTP issuer name for 2FA QR codes
TOTP_ISSUER=CloudNest

# Proxmox VE API credentials
PROXMOX_HOST=proxmox-host:8006
PROXMOX_API_TOKEN_ID=realm!token-id
PROXMOX_API_TOKEN_SECRET=your-token-secret
PROXMOX_NODE=pve
PROXMOX_STORAGE=local-lvm

# SMTP (optional — email verification, password reset, reports)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cloudnest.io

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Node
NODE_ENV=development
PORT=3000
