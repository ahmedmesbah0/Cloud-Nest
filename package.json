{
  "name": "cloudnest",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev": "npm run dev:api & npm run dev:web",
    "build": "npm run build -w packages/shared-types && npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/web",
    "test": "npm run test -w apps/api",
    "test:e2e": "npm run test:e2e -w apps/api",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "devDependencies": {
    "@types/passport-http-bearer": "^1.0.42",
    "eslint-config-next": "^16.2.10",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "axios": "^1.18.1",
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "passport-http-bearer": "^1.0.1",
    "socket.io": "^4.8.3"
  }
}
